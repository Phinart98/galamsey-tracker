# ============================================================
# Galamsey Tracker — environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase ---
# Nuxt 3: public vars need the NUXT_PUBLIC_ prefix for runtime override.
# Private vars need the NUXT_ prefix. See apps/web/nuxt.config.ts comments.
NUXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NUXT_SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Direct connection (port 5432 — session mode): use for migrations + pipelines.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Pooled connection (port 6543 — transaction mode): use for FastAPI request handlers.
DATABASE_URL_POOLED=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=<account-id>
CLOUDFLARE_R2_ACCESS_KEY_ID=<r2-access-key-id>
CLOUDFLARE_R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
CLOUDFLARE_R2_BUCKET=galamsey-static
CLOUDFLARE_R2_PUBLIC_URL=https://<custom-domain-or-r2-dev-url>

# --- Africa's Talking ---
AFRICASTALKING_API_KEY=<api-key>
AFRICASTALKING_USERNAME=<username>
AFRICASTALKING_SHORTCODE=<shortcode>
AFRICASTALKING_USSD_CODE=*xxx#

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=<bot-token>

# --- Anthropic (Claude API for news extraction in Phase 7) ---
ANTHROPIC_API_KEY=<api-key>

# --- GFW Data API ---
GFW_API_KEY=<api-key>

# --- Microsoft Planetary Computer (Sentinel-1 / Sentinel-2) ---
# No key needed for public STAC access; add if using signed tokens
# PLANETARY_COMPUTER_SUBSCRIPTION_KEY=<key>

# --- Vercel (web deployment) ---
# Set in Vercel dashboard, not here

# --- Google Cloud (API backend on Cloud Run) ---
GCP_PROJECT_ID=<gcp-project-id>
GCP_REGION=europe-west2

# --- Sentry (observability) ---
SENTRY_DSN=<dsn>
SENTRY_ENVIRONMENT=development

# --- App config ---
APP_ENV=development
API_BASE_URL=http://localhost:8000
MARTIN_BASE_URL=http://localhost:3001
TITILER_BASE_URL=http://localhost:8080

# --- FastAPI CORS (apps/api) ---
# Comma-separated list of allowed origins (exact match).
# Defaults preserve localhost:3000 + galamseytracker.org if these are unset.
CORS_ORIGINS=http://localhost:3000,https://galamseytracker.org
# Optional regex covering Vercel preview deploys (web-*.vercel.app pattern) +
# the production custom domain. Set on the Cloud Run service.
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?(vercel\.app|galamseytracker\.org)$

# --- Nuxt public runtime (apps/web) ---
# Set on Vercel dashboard for Production + Preview, NOT here.
# NUXT_PUBLIC_MARTIN_BASE_URL=https://martin-<hash>.<region>.run.app
# NUXT_PUBLIC_API_BASE_URL=https://api-<hash>.<region>.run.app
